# MongoDB connection string.
# Local docker example: mongodb://localhost:27017/tracker
MONGODB_URI=mongodb://localhost:27017/tracker

# NextAuth (v4) secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-a-random-secret

# Public URL NextAuth uses to build callback/redirect links.
NEXTAUTH_URL=https://tracker.amanhogan.com
